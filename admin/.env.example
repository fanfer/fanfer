# === Vercel Environment Variables ===
# Set these in Vercel Dashboard → Settings → Environment Variables

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=  # Run: cd admin && npm run hash-password
JWT_SECRET=           # Random string, min 32 chars

# GitHub API (for reading/writing blog files)
GITHUB_TOKEN=         # GitHub Personal Access Token with 'repo' scope
GITHUB_REPO=fanfer/fanfer
GITHUB_BRANCH=main

# Twikoo comment system (optional)
TWIKOO_API_URL=https://twikko.fanfer.top
TWIKOO_ADMIN_PASSWORD=
