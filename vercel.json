{
  "buildCommand": "cd admin/client && npm run build && cd ../../web && npm run build",
  "installCommand": "npm install && cd admin/client && npm install && cd ../../web && npm install",
  "outputDirectory": "web/dist",
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/(.*)", "destination": "/admin/index.html" },
    { "source": "/api/auth/login", "destination": "/api/fn-auth?action=login" },
    { "source": "/api/auth/verify", "destination": "/api/fn-auth?action=verify" },
    { "source": "/api/posts/:filename", "destination": "/api/fn-posts?filename=:filename" },
    { "source": "/api/posts", "destination": "/api/fn-posts" },
    { "source": "/api/pages/:slug", "destination": "/api/fn-pages?slug=:slug" },
    { "source": "/api/pages", "destination": "/api/fn-pages" },
    { "source": "/api/drafts/pdf", "destination": "/api/fn-drafts?action=pdf" },
    { "source": "/api/drafts/:filename/publish", "destination": "/api/fn-drafts?filename=:filename&action=publish" },
    { "source": "/api/drafts/:filename", "destination": "/api/fn-drafts?filename=:filename" },
    { "source": "/api/drafts", "destination": "/api/fn-drafts" },
    { "source": "/api/comments/:id", "destination": "/api/fn-comments?id=:id" },
    { "source": "/api/comments", "destination": "/api/fn-comments" },
    { "source": "/api/upload/:filename", "destination": "/api/fn-upload?filename=:filename" },
    { "source": "/api/upload", "destination": "/api/fn-upload" },
    { "source": "/api/dashboard/stats", "destination": "/api/fn-dashboard" },
    { "source": "/api/config/:type", "destination": "/api/fn-config?type=:type&resource=config" },
    { "source": "/api/data/:type", "destination": "/api/fn-config?type=:type&resource=data" }
  ]
}
